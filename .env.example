# ── Required for FRED macro indicators ──────────────────────────────────────
# Get a free key at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# ── Optional: NewsAPI for better news feed ───────────────────────────────────
# Get a free key at: https://newsapi.org/register
# Without this, falls back to Google News RSS (no key needed)
NEWS_API_KEY=your_newsapi_key_here

# ── Database (leave as-is for local SQLite) ──────────────────────────────────
DATABASE_URL=sqlite:///./macro_dashboard.db
